# ==========================================
# PixWave Server — Environment Variables
# ==========================================
# Copy this file to .env and fill in your keys.

# Server
PORT=3000
NODE_ENV=development

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# OpenWeather
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_LAT=39.9042
OPENWEATHER_LON=116.4074

# Feishu (Lark) Calendar
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Netease Cloud Music (local proxy)
NETEASE_API_BASE=http://localhost:3001

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# Fish Audio TTS
FISHAUDIO_API_KEY=your_fishaudio_api_key
FISHAUDIO_VOICE_ID=default
